# Copy to backend/.env and fill in. With NO values set, the app runs fully offline:
# the LLM provider falls back to a scripted local patient stub and the data layer
# uses bundled mimic_demo + synthetic cases.

# LLM provider: anthropic | openai | local   (default: local)
LLM_PROVIDER=local

# Anthropic (default cloud provider). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (optional alternative)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Data sources to enable, comma-separated: mimic_demo,synthetic,mimic_full,mietic
# (mimic_full / mietic only work once you've placed credentialed data — see their READMEs)
ENABLED_SOURCES=mimic_demo,synthetic

# SQLite database path (relative to backend/)
DATABASE_URL=sqlite:///./ed_triage.sqlite3

# Comma-separated browser origins allowed by CORS. Add your deployed frontend URL
# here when deploying (default covers the Vite dev server).
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
